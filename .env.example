# Copy to .env and fill in. NEVER commit the real .env.
# Generate a key: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SITE_DOMAIN=motorverzekering.nl
# Canonical origin for structured-data @id's + canonical URLs (default https://{SITE_DOMAIN}).
SITE_ORIGIN=https://motorverzekering.nl

# Image / content tooling (optional in dev)
PEXELS_API_KEY=
ANTHROPIC_API_KEY=

# RISK Insurance API — premie-vergelijker/afsluit-tool (particuliere motor, spec V9).
# Credentials live ONLY here (server-side); the browser never sees them.
RISK_API_BASE=https://api.acc.risk.nl/InsuranceAPI
RISK_API_USERNAME=
RISK_API_PASSWORD=
RISK_BROKER_ID=
RISK_API_VERSION=9.0
# Product version (PP_PRDVERS) that RISK requires in the calculate body — RISK
# levert de exacte waarde bij het motor-account.
RISK_MOTOR_PRODUCT_VERSION=

# Trustpilot Public API — weekly score + reviews fetch (manage.py fetch_trustpilot).
TRUSTPILOT_API_KEY=
TRUSTPILOT_DOMAIN=
TRUSTPILOT_BUSINESS_UNIT_ID=

# Production database (Railway zet DATABASE_URL automatisch bij een Postgres-plugin):
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Alleen productie (Railway) ──────────────────────────────────────────────
# Zet in productie: DEBUG=False, een echte SECRET_KEY, ALLOWED_HOSTS/CSRF op je
# domein (Railway vult RAILWAY_PUBLIC_DOMAIN automatisch aan), en RISK_API_BASE
# naar de PRODUCTIE-RISK-URL (niet acc) zodra je live-credentials hebt.
# bootstrap_site maakt bij de EERSTE deploy een admin-account uit deze variabelen:
# DJANGO_SUPERUSER_USERNAME=
# DJANGO_SUPERUSER_PASSWORD=
# DJANGO_SUPERUSER_EMAIL=

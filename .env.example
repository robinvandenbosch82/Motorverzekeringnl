# Copy to .env and fill in. NEVER commit the real .env.
# Generate a key: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SITE_DOMAIN=bestelautoverzekering.nl
# Canonical origin for structured-data @id's + canonical URLs (default https://{SITE_DOMAIN}).
SITE_ORIGIN=https://bestelautoverzekering.nl

# Image / content tooling (optional in dev)
PEXELS_API_KEY=
ANTHROPIC_API_KEY=

# Trustpilot Public API — weekly score + reviews fetch (manage.py fetch_trustpilot).
# Free API key from your Trustpilot Business account. Empty = fetch is a no-op.
TRUSTPILOT_API_KEY=
TRUSTPILOT_DOMAIN=autoverzekering.nl
# Optional: skip the domain lookup by pinning the business-unit id.
TRUSTPILOT_BUSINESS_UNIT_ID=

# Production database (uncomment in prod):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
